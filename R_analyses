tiplabels(pch = 21, bg = proximal_tip_state_colors, col = "black", cex = 1.5, offset = -0.02)


# Ancestral State Reconstruction Analysis ASR ----
# every character, test equal rates model, all rates different model, and symmetrical model.
# test maddfitz root prior and yang root prior
# models with the lowest AICc score are best fit
# Best fitting model will be first with other ones after

# LATERAL DUCTS of DISTAL GLAND ASR ----
# ER MODEL, MADDFITZ ROOT PRIOR - BEST 
fitcorER.maddfitz <- rayDISC(tree_chrono, gland_df, 
                             model = "ER", node.states = "marginal",
                             state.recon = "subsequently", root.p = "maddfitz")
fitcorER.maddfitz # AIC 31.96 AICc 32.12
fitcorER.maddfitz$states
plotTree(tree_chrono) 
nodelabels(pie = fitcorER.maddfitz$states, piecol = gland_state_colors) #add probability pies to node
tiplabels(pch = 21, bg = gland_tip_state_colors, col = "black", cex = 1.5, offset = -0.01)
legend("topleft", 
       legend = c("Gland absent (0)", "Typical duct (1)", "Expanded duct (2)"),  # adjust labels as needed
       fill = gland_state_colors, 
       border = "black", 
       cex = 0.9, 
       bty = "n")   # bty="n" removes the box
fitcorER.maddfitz$states
plotTree(tree_chrono) 
nodelabels()
#nodelables of phylogeny different than output because rayDISC retur states a matriz where row 1 is the first internal node, does not include tips
n_tips <- length(tree_chrono$tip.label)
n_nodes <- tree_chrono$Nnode
# Create a named version of the states matrix
states_labeled <- fitcorER.maddfitz$states
rownames(states_labeled) <- (n_tips + 1):(n_tips + n_nodes)
# Now you can look up any node by its ape/phytools node number
states_labeled
# Plot with both pies AND node number labels so you can cross-reference.
plotTree(tree_chrono)
nodelabels(pie = fitcorER.maddfitz$states, 
           piecol = gland_state_colors, 
           cex = 0.5)
nodelabels(text = (n_tips + 1):(n_tips + n_nodes), 
           adj = c(0, -0.5),   # offset text above the pie
           cex = 0.6, 
           frame = "none")
tiplabels(pch = 21, bg = gland_tip_state_colors, 
          col = "black", cex = 1.5, offset = -0.01)

