# PART TWO - CORRELATED EVOLUTION MODELING ----
#cophylogenetic trait analysis can be done using Pagel’s (1994) discrete model of correlated trait evolution
#I'm looking at if there is correlation between using attachment threads for silk and the modified reservoir chamber
#A. First I will use Pagel's discrete model of correlated trait evolution to test independence or dependence of traits
#B. Then I will use Simmap for stochastic character mapping, which asks: Given these traits and the tree, how could the joint states have evolved along the branches
#C. Finally I will visualize the Simmap and the summarization of all simulations

# LOAD FILES & PREP DATA ----
# Load tree
# will be using the same starting tree, create new tree pruned 
tree <- read.tree("tree_newick.txt") 
tree.pruned <- collapse.singles(tree) #collape single nodes (the extra sunampithoe and neoxenodice)
plot(tree.pruned)

# Load trait data 
#column 1 morphology (0=not modified chamber, 1 = modified chamber)
#column 2 ecology (0=no attachment threads, 1= attachment threads)
mydata <- read.csv("chamber_silkthreads.csv", row.names = 1)

#Create named vectors for each trait
morph <- setNames(mydata$morphology, rownames(mydata))
ecol  <- setNames(mydata$ecology, rownames(mydata))
# Make sure they are factors or binary
morph <- as.factor(morph)
ecol  <- as.factor(ecol)


# A. PERFORM PAGEL'S test CORRELATED MODEL ----
result <- fitPagel(tree.pruned, morph, ecol, model = "ARD", method = "fitDiscrete")
#I'm using an ARD model since it is better at capturing asymmetry in dependent evolution
#I'm using the fitDiscrete method since it uses a markov model along the phylogeny. I don't have a lot of priors or states, and my data set is relatively small so 
#I don't see the need to use bayestraits or intergrate a more complex model.

print(result) # Inspect results
#The test compares two models: 
#Independent evolution of trait 1 and trait 2.
# Dependent evolution (one trait’s transition rates depend on the state of the other).
#From these results it looks like the dependent model has more support. 
#Looks like the evo transition between two states is dependent of eachother
str(result)
# transition rate matrix for dependent model
result$dependent.Q
#Morphology changes from 1→0 readily when ecology = 0 (17.6).
#Morphology changes from 0→1 readily when ecology = 1 (9.17).
#ecological transition depends strongly on morphology 
plot(result$dependent.Q)


# B. STOCHASTIC CHARACTER MAPIING & VISUALIZING ----
#I have two binary traits, so I can combine them into a single “joint character” with 4 possible states (0|0, 0|1, 1|0, 1|1), 
#and then do stochastic character mapping simulations 
#assing join traits
joint <- paste(morph, ecol, sep = "|")
joint <- factor(joint, levels = c("0|0","0|1","1|0","1|1"))
joint <- setNames(joint, names(morph))
levels(joint) 
unique(joint) #check to see if they are consistent
#They have different matrix so need to drop the states that are not present (1|0 and 0|1)
joint_reduced <- droplevels(joint)   # drops unused states
levels(joint_reduced) # should now be "0|0" and "1|1"

# Allow simmap to re-estimate the transition rates just using 0|0 and 1|1
simmap <- make.simmap(tree.pruned, joint_reduced, model = "ARD", nsim = 100)
#Transitions 0|0 → 1|1 happen at rate ≈ 0.37.  
#Transitions 1|1 → 0|0 were estimated as 0 (absorbing).  
#So once the clade evolves into `1|1`, the model says it never reverts.  

#get tree node and tip numbers:
n_tips <- length(tree.pruned$tip.label)
n_nodes <- tree.pruned$Nnode

#Visualize one single tree just to see what it looks like
cols <- setNames(c("gray80","purple"), c("0|0","1|1"))
#Plot one sampling
plotSimmap(simmap[[97]] , cols, fsize = 0.7, lwd = 4, pts = FALSE) #this is just for 1 simulation, can look at any of the 100 simulations
nodelabels(text = (n_tips + 1):(n_tips + n_nodes), 
           adj = c(0, -0.5),  
           cex = 0.6, 
           frame = "none")
add.simmap.legend(colors = cols, prompt = FALSE, x = 0, y = 27)  #Add legend in top-left slightly below the top
# Add node pies, use describe.simmap to get posterior probabilities at nodes
simmap_summary <- describe.simmap(simmap)
# simmap_summary$ace is a matrix of posterior probabilities for each state at each node
nodelabels(pie = simmap_summary$ace, piecol = cols, cex = 0.7)

#Look at node state posterior probabilities 
node_pp <- simmap_summary$ace
node_pp
#node 44 cerapus (Notopoma) and dulichia
#0|0 0.60, 1|1 0.40 so more likely not at this node

#node 42 sunamphitoe and photis
#0|0 0.55, 1|1 0.45 so likely not at this node

#For more info on all the simulation
describe.simmap(simmap)$count #look at the simulations
simmap_summary <- describe.simmap(simmap)  # simmap is the list of 100 maps
simmap_summary
#trees have 3.1 changes between states on average

#C. VISUALIZE STOCHASTIC CHARACTER MAPPING SIMULATION RESULTS
#visualize all simulations 
# Set the layout to a 10 x 10 grid (100 plots)
par(mfcol = c(10, 10), mar = c(0.5, 0.5, 0.5, 0.5))
# Plot all 100 maps
lapply(simmap, plotSimmap, ftype = "off", lwd = 1)
dmap=densityMap(simmap, res=100)
dev.off()
# Define custom colors for states
cols <- setNames(c("gray80","purple"), c("0|0", "1|1"))
dmap <- setMap(dmap, cols)
# Plot the density map (average) along the tree for final figure
plot(dmap, fsize = c(0.7, 0.9), lwd = 3, outline = TRUE, legend = TRUE)
