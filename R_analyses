#This R script includes all silk-spinning character analyses used for the manuscript Diversification of the Corophiida amphipod silk-spinning systems (McKim et al., in review)
#All the following analyses were conducted by Siena McKim 

#Part one is the ancestral state reconstruction analysis for key silk-spinning traits in the Corophiida
#Part two are the correlative evolution analyses including Pagel's test for dependence and stochastic character mapping of joint traits

#Figures produced from these analysis were exported as svg files and then edited and arranged in Adobe Illustrator. 
#full taxonomic names added to the tips in final figures
       #keep in mind cer_spp. is actually Notopoma sp. A. Changed this in the figure. 

# SETTING UP ENVRIONMENT ----
library(phylogram) #allows us to read in our phylogeny
library(ape) #provides the chronos function for making our tree ultrametric
library(corHMM) #provide rayDISC function for ASR
library(phytools) #allows us to do lots of stuff with our phylogeny, like plot & get node/tip info
# set working directory. This will make calling all data files easier if everything is in the same folder. 
setwd("") #enter the path to the folder where you have saved your files 

#PART ONE - ANCESTRAL STATE RECONSTRUCTION ----
#marginal ancestral state reconstruction analysis using corHMM (rayDISC function)

# IMPORT PHYLOGENY & MAKE ULTRAMETRIC ----

#names on phylogeny need to match exactly with character df
tree <- read.tree("tree_newick.txt") #tree_newick.txt file
plot(tree) #look at tree
nodelabels() #look at assigned node lables
tree_pruned <- collapse.singles(tree) #collapse nodes with single lineages
plot(tree_pruned) #look at pruned tree
nodelabels() #Take a look at tree. Looks good now!
#Need tree to be ultrametric. But first, see if the tree is rooted.
is.rooted(tree_pruned) #TRUE
#create ultrametric tree with correlated model. Lambda smoothing parameter, model specifies model of sub rate variation among branches correlated
tree_chrono <- chronos(tree_pruned, lambda = 1, model = "correlated")
# test if tree is ultrametric
ultratree <- read.tree(text=write.tree(tree_chrono)) 
is.ultrametric(ultratree) # want to see "TRUE" returned
plot(tree_chrono) #take a look, see tips end in same place
nodelabels() #double checking no hidden nodes
tiplabels() #double check tip labels

#IMPORT CHARACTER TABLE, ASSIGN COLORS, & CHECK LABELING ----

#four characters for this anlysis, character state tables available within same directory

#LATERAL DUCTS of DISTAL GLANDS ----
#distal glands have expanded lateral duct in some taxa, 0 - absent 1 - typical 2 - expanded
distal_gland_states <- read.csv("distal_gland_states.csv")
gland_df <- data.frame(distal_gland_states) #convert table into a data frame 
summary(gland_df) #take a look at the data frame. 
gland_df$state #double check states look right
plot(tree_chrono) #double check I have my tree
nodelabels() #double checking no hidden nodes

# Define colors so that index = state + 1 (since R indexing starts at 1)
gland_state_colors <- c("white", "lightblue", "darkblue")  
# 0 -> white (absent), 1 -> lightblue (typical), 2 -> darkblue (expanded)
# Make sure your dataframe is ordered to match tree tips
gland_df_ordered <- gland_df[match(tree_chrono$tip.label, gland_df$species), ]
#look at gland_df_ordered to double check that there are no mismatches & things in the df aren't spelled wrong
# Now assign tip colors based on state
gland_tip_state_colors <- gland_state_colors[gland_df_ordered$state + 1]
plot(tree_chrono, show.tip.label = TRUE)
tiplabels(pch = 21, bg = gland_tip_state_colors, col = "black", cex = 1.5, offset = -0.02)


# DACTYLUS SLIT LOCATION ----
dslit_states <- read.csv("dactylus_slit_states.csv") #read in 
dslit_df <- data.frame(dslit_states) #convert table into a data frame 
summary(dslit_df) #take a look at the data frame. 
dslit_df$state #double check states look right
plot(tree_chrono) #double check I have my tree
nodelabels() #double checking no hidden nodes

# Define colors so that index = state + 1 (since R indexing starts at 1)
dslit_state_colors <- c("white", "limegreen", "darkgreen")  
# 0 -> white (absent), 1 -> limegreen (slit same side as sensillum), 2 -> darkgreen (slit opposite of sensillum)
# Make sure your dataframe is ordered to match tree tips
dslit_df_ordered <- dslit_df[match(tree_chrono$tip.label, dslit_df$species), ]
#look at gland_df_ordered to double check that there are no mismatches & things in the df aren't spelled wrong
# Now assign tip colors based on state
dslit_tip_state_colors <- dslit_state_colors[dslit_df_ordered$state + 1]
plot(tree_chrono, show.tip.label = TRUE)
tiplabels(pch = 21, bg = dslit_tip_state_colors, col = "black", cex = 1.5, offset = -0.02)


